{
  "name": "surikata",
  "version": "1.0.0",
  "description": "Surikata — minimalist multi-user RSS reader on Hono + Cloudflare Workers + D1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state --test-scheduled",
    "db:migrate:local": "wrangler d1 execute surikata-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute surikata-db --remote --file=./migrations/0001_init.sql",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --watch",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241004.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0"
  },
  "allowScripts": {
    "esbuild@0.17.19": true,
    "sharp@0.33.5": true,
    "workerd@1.20250718.0": true
  }
}
